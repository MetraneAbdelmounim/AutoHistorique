<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Production backend (self-signed cert on raw IP) -->
    <!-- Trusts system CAs + user-installed certs for this host only -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="false">102.50.247.101</domain>
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
            <!-- To embed the self-signed cert, drop it at
                 android/app/src/main/res/raw/server_cert.pem and uncomment:
            <certificates src="@raw/server_cert"/>
            -->
        </trust-anchors>
    </domain-config>

    <!-- Dev backends (LAN / emulator) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">10.0.3.2</domain>
        <domain includeSubdomains="true">192.168.0.0</domain>
        <domain includeSubdomains="true">192.168.1.0</domain>
        <domain includeSubdomains="true">192.168.10.86</domain>
    </domain-config>

    <!-- Everything else: HTTPS-only with system CAs -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
