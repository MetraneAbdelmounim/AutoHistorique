# ─── Copy to .env on the server, then fill in real values ───
# docker-compose picks this up automatically when you run `docker compose up`

# MongoDB database name (no authentication — isolated on internal docker network)
MONGO_DB=autohistorique

# JWT — MUST be long and random in production (≥ 64 chars). Use:
#   openssl rand -base64 64
JWT_SECRET=change-me-openssl-rand-base64-64
JWT_EXPIRES_IN=8h

# Frontend origin (web). Capacitor mobile app origins are always allowed.
FRONTEND_URL=https://autohistorique.ma
